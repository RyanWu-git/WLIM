<Window x:Class="ChatAppWpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ChatAppWpf.Converters"
        Title="聊天"
        Width="1200"
        Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
  <Window.Resources>
    <conv:IsMineAlignmentConverter x:Key="IsMineAlignmentConverter" />
    <conv:IsMineBrushConverter x:Key="IsMineBrushConverter" />
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="300" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Grid Grid.Column="0" Background="#2B2B2B">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TabControl Grid.Row="0"
                  Margin="12"
                  Background="#2B2B2B"
                  BorderThickness="0">
        <TabItem Header="聊天">
          <ListBox ItemsSource="{Binding Sessions}"
                   SelectedItem="{Binding SelectedSession}"
                   Background="#2B2B2B"
                   BorderThickness="0"
                   Foreground="White"
                   Margin="0,8,0,0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="10"
                        Margin="0,0,0,8"
                        Background="#3A3A3A"
                        CornerRadius="8">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Type}" Foreground="#B0B0B0" FontSize="12" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>

        <TabItem Header="好友">
          <ListBox ItemsSource="{Binding Contacts}"
                   Background="#2B2B2B"
                   BorderThickness="0"
                   Foreground="White"
                   Margin="0,8,0,0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="10"
                        Margin="0,0,0,8"
                        Background="#3A3A3A"
                        CornerRadius="8">
                  <StackPanel>
                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Kind}" Foreground="#B0B0B0" FontSize="12" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>
      </TabControl>

      <Border Grid.Row="2"
              Padding="12"
              BorderThickness="0,1,0,0"
              BorderBrush="#404040">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse Width="32" Height="32" Fill="#666" />
          <TextBlock Text="{Binding CurrentUserEmail}"
                     Foreground="White"
                     Margin="10,0,0,0"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="18,14">
        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="#222" />
      </Border>

      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#F5F5F5">
        <ItemsControl ItemsSource="{Binding Messages}" Margin="18,14">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,0,0,12">
                <Border Padding="12,8"
                        CornerRadius="10"
                        MaxWidth="520">
                  <Border.HorizontalAlignment>
                    <MultiBinding Converter="{StaticResource IsMineAlignmentConverter}">
                      <Binding Path="SenderId" />
                      <Binding Path="DataContext.CurrentUserId" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                  </Border.HorizontalAlignment>
                  <Border.Background>
                    <MultiBinding Converter="{StaticResource IsMineBrushConverter}">
                      <Binding Path="SenderId" />
                      <Binding Path="DataContext.CurrentUserId" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                  </Border.Background>
                  <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="#111" />
                </Border>
                <TextBlock Text="{Binding CreatedAt}"
                           FontSize="10"
                           Foreground="#999">
                  <TextBlock.HorizontalAlignment>
                    <MultiBinding Converter="{StaticResource IsMineAlignmentConverter}">
                      <Binding Path="SenderId" />
                      <Binding Path="DataContext.CurrentUserId" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                  </TextBlock.HorizontalAlignment>
                </TextBlock>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="18,12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox x:Name="MessageBox"
                   Grid.Column="0"
                   Text="{Binding NewMessage, UpdateSourceTrigger=PropertyChanged}"
                   AcceptsReturn="True"
                   MinHeight="44"
                   MaxHeight="120"
                   Padding="12,10"
                   Background="#F3F4F6"
                   BorderThickness="0"
                   VerticalScrollBarVisibility="Auto" />
          <Button Grid.Column="1"
                  Content="发送"
                  Margin="10,0,0,0"
                  Padding="18,10"
                  Background="#2563EB"
                  Foreground="White"
                  BorderThickness="0"
                  Command="{Binding SendCommand}" />
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
